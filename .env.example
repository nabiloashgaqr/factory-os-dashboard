# ─────────────────────────────────────────────────────────────
# FactoryOS™ Live Dashboard — Optional server-side defaults
# ─────────────────────────────────────────────────────────────
# These are OPTIONAL. The app is designed to be configured fully
# from the in-app Settings panel (stored in the browser only).
#
# If you prefer to keep keys on the server instead of the browser,
# set them here. The API routes will fall back to these values
# when the client does not send credentials.
#
# ⚠️ NEVER commit a real .env file. Keep your keys private.

# Notion
NOTION_TOKEN=
NOTION_KPI_DB_ID=
NOTION_ACTION_DB_ID=
NOTION_PROGRESS_DB_ID=
NOTION_INVENTORY_DB_ID=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
